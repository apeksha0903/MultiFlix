# Server
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/multiflix
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# TMDB
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_TOKEN=your_tmdb_bearer_token
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# Email provider: "mailtrap" for dev, "resend" for prod
EMAIL_PROVIDER=mailtrap

# Mailtrap (dev/testing)
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_user
MAILTRAP_PASS=your_mailtrap_pass

# Resend (production)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=MultiFlix <noreply@yourdomain.com>

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Session (needed for Passport OAuth flow)
SESSION_SECRET=replace_with_long_random_string
